# ─────────────────────────────────────────────
# DevBoard API — Environment Variables Example
# Copy this file to .env and fill in the values
# cp .env.example .env
# ─────────────────────────────────────────────

# ── Server ────────────────────────────────────
SERVER_ADDRESS=:8080

# ── Database ──────────────────────────────────
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=disable
DATABASE_URL=postgres://devboard_user:changeme@localhost:5432/devboard_db?sslmode=disable

# ── JWT Authentication ─────────────────────────
# Use a long, random secret (min 32 characters recommended)
JWT_SECRET=your-super-secret-jwt-key-change-this

# Token expiration (in hours)
ACCESS_TOKEN_EXPIRE_HOURS=720
REFRESH_TOKEN_EXPIRE_HOURS=4320

# Cookie settings
ACCESS_TOKEN_COOKIE_NAME=access_token
REFRESH_TOKEN_COOKIE_NAME=refresh_token
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
COOKIE_SAME_SITE=Lax

# ── CORS ──────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── SMTP / Email ──────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_EMAIL=noreply@example.com
SMTP_PASSWORD=your-smtp-password

# ── Password Reset ────────────────────────────
PASSWORD_RESET_EXPIRE_MINUTES=60
PASSWORD_RESET_BASE_URL=http://localhost:5173/reset-password
